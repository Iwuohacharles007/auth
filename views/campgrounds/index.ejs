

<!-- MAPBOX CSS -->
<link href='https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.css' rel='stylesheet' />

<!-- GOOGLE FONTS -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'DM Sans', sans-serif;
        background-color: #0f1117;
        color: #e8e8e0;
        overflow-x: hidden;
    }

    /* ===== FULL-WIDTH CLUSTER MAP ===== */
    .cluster-map-wrap {
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
    }

    #map {
        width: 100%;
        height: 460px;
        display: block;
    }

    /* ===== FULL-WIDTH HERO BANNER ===== */
    .index-hero {
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        background: linear-gradient(135deg, #0f1117 0%, #1a1d2e 50%, #0f1117 100%);
        border-bottom: 1px solid #1e2130;
        padding: 52px 60px 44px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .hero-text h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.2rem, 5vw, 3.5rem);
        color: #f0ede6;
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.5px;
    }

    .hero-text h1 span { color: #7ed99a; font-style: italic; }

    .hero-text p {
        color: #666;
        font-size: 1rem;
        margin-top: 10px;
        font-weight: 300;
    }

    .btn-add {
        padding: 14px 32px;
        background: linear-gradient(135deg, #2d5a3d, #3a7a52);
        border: 1px solid #3a7a52;
        color: #7ed99a;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.25s ease;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .btn-add:hover {
        background: linear-gradient(135deg, #3a7a52, #4a9a62);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(61,160,90,0.25);
        text-decoration: none;
    }

    @media (max-width: 768px) {
        .index-hero { padding: 36px 20px; }
    }

    /* ===== FULL-WIDTH CONTENT WRAPPER ===== */
    .full-page-wrapper {
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        padding: 48px 60px;
    }

    @media (max-width: 768px) {
        .full-page-wrapper { padding: 32px 16px; }
    }

    /* ===== STATS BAR ===== */
    .stats-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 36px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .stats-count { font-size: 0.9rem; color: #555; }
    .stats-count strong { color: #7ed99a; }

    /* ===== CAMPGROUND GRID ===== */
    .camps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 28px;
    }

    @media (max-width: 500px) {
        .camps-grid { grid-template-columns: 1fr; }
    }

    /* ===== CAMP CARD ===== */
    .camp-card {
        background: #181b26;
        border: 1px solid #252836;
        border-radius: 18px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        text-decoration: none;
        color: inherit;
        cursor: pointer;
    }

    .camp-card:hover {
        transform: translateY(-6px);
        border-color: #3a7a52;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        color: inherit;
        text-decoration: none;
    }

    .camp-card-img-wrap {
        position: relative;
        overflow: hidden;
        height: 220px;
    }

    .camp-card-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .camp-card:hover .camp-card-img-wrap img { transform: scale(1.06); }

    .img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(15,17,23,0.8) 0%, transparent 50%);
        pointer-events: none;
    }

    .price-tag {
        position: absolute;
        top: 14px;
        right: 14px;
        background: rgba(15,17,23,0.85);
        border: 1px solid #3a7a52;
        color: #7ed99a;
        padding: 5px 14px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        backdrop-filter: blur(6px);
    }

    .review-tag {
        position: absolute;
        bottom: 12px;
        left: 14px;
        background: rgba(15,17,23,0.75);
        border: 1px solid #2a2d3a;
        color: #888;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        backdrop-filter: blur(6px);
    }

    .review-tag i { color: #f0c040; margin-right: 4px; }

    .camp-card-body {
        padding: 22px 24px 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .camp-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.25rem;
        color: #f0ede6;
        margin-bottom: 8px;
        line-height: 1.3;
    }

    .camp-card-location {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #6c8ebf;
        font-size: 0.82rem;
        margin-bottom: 12px;
    }

    .camp-card-desc {
        color: #666;
        font-size: 0.88rem;
        line-height: 1.65;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .camp-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid #1e2130;
    }

    .btn-view {
        padding: 9px 22px;
        background: linear-gradient(135deg, #1e3a2a, #2d5a3d);
        border: 1px solid #3a7a52;
        color: #7ed99a;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .camp-card:hover .btn-view {
        background: linear-gradient(135deg, #3a7a52, #4a9a62);
        color: #fff;
    }

    .card-arrow {
        color: #333;
        font-size: 1.1rem;
        transition: color 0.2s, transform 0.2s;
    }

    .camp-card:hover .card-arrow {
        color: #7ed99a;
        transform: translateX(4px);
    }

    /* ===== EMPTY STATE ===== */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #444;
        grid-column: 1 / -1;
    }

    .empty-state i { font-size: 3.5rem; margin-bottom: 16px; display: block; color: #2a2d3a; }
    .empty-state p { font-size: 1rem; margin-bottom: 24px; }

    /* ===== FOOTER BAR ===== */
    .page-footer-bar {
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        background: #12151f;
        border-top: 1px solid #1e2130;
        padding: 22px 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 20px;
    }

    .footer-brand { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #444; }
    .footer-brand span { color: #7ed99a; }

    /* ===== MAPBOX POPUP DARK OVERRIDE ===== */
    .mapboxgl-popup-content {
        background: #181b26 !important;
        border: 1px solid #2a2d3a !important;
        border-radius: 12px !important;
        padding: 0 !important;
        overflow: hidden;
        min-width: 220px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6) !important;
    }

    .mapboxgl-popup-tip { border-top-color: #181b26 !important; }

    .mapboxgl-popup-close-button {
        color: #555 !important;
        font-size: 1.1rem !important;
        padding: 6px 10px !important;
        z-index: 10;
        background: transparent !important;
    }

    .mapboxgl-popup-close-button:hover { color: #fff !important; }

    .popup-img {
        width: 100%;
        height: 110px;
        object-fit: cover;
        display: block;
    }

    .popup-no-img {
        height: 80px;
        background: #1e2130;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2a2d3a;
        font-size: 1.8rem;
    }

    .popup-body { padding: 12px 14px 14px; }

    .popup-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        color: #f0ede6;
        margin-bottom: 4px;
    }

    .popup-location { font-size: 0.78rem; color: #6c8ebf; margin-bottom: 5px; }
    .popup-location i { margin-right: 4px; }

    .popup-price { font-size: 0.82rem; color: #7ed99a; font-weight: 600; margin-bottom: 10px; }

    .popup-btn {
        display: block;
        text-align: center;
        padding: 8px;
        background: linear-gradient(135deg, #2d5a3d, #3a7a52);
        border: 1px solid #3a7a52;
        color: #7ed99a !important;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.2s;
    }

    .popup-btn:hover {
        background: linear-gradient(135deg, #3a7a52, #4a9a62);
        color: #fff !important;
    }
</style>

<!-- FULL-WIDTH CLUSTER MAP -->
<div class="cluster-map-wrap">
    <div id="map"></div>
</div>

<!-- HERO BANNER -->
<div class="index-hero">
    <div class="hero-text">
        <h1>Explore <span>Campgrounds</span></h1>
        <p><%= campgrounds.length %> destinations waiting for you</p>
    </div>
    <a href="/campgrounds/new" class="btn-add">
        <i class="fas fa-plus"></i> Add Campground
    </a>
</div>

<!-- MAIN CONTENT -->
<div class="full-page-wrapper">

    <div class="stats-bar">
        <span class="stats-count">
            Showing <strong><%= campgrounds.length %></strong> campground<%= campgrounds.length !== 1 ? 's' : '' %>
        </span>
    </div>

    <div class="camps-grid">
        <% if (campgrounds.length === 0) { %>
            <div class="empty-state">
                <i class="fas fa-campground"></i>
                <p>No campgrounds yet. Be the first to add one!</p>
                <a href="/campgrounds/new" class="btn-add">
                    <i class="fas fa-plus"></i> Add Campground
                </a>
            </div>
        <% } %>

        <% campgrounds.forEach(campground => { %>
            <a href="/campgrounds/<%= campground._id %>" class="camp-card">
                <div class="camp-card-img-wrap">
                    <img
                        src="<%= campground.images && campground.images.length ? campground.images[0].url : 'https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=600&auto=format&fit=crop' %>"
                        alt="<%= campground.title %>"
                        loading="lazy"
                    >
                    <div class="img-overlay"></div>
                    <% if (campground.price) { %>
                        <span class="price-tag">$<%= campground.price %>/night</span>
                    <% } %>
                    <% if (campground.reviews && campground.reviews.length > 0) { %>
                        <span class="review-tag">
                            <i class="fas fa-star"></i>
                            <%= campground.reviews.length %> review<%= campground.reviews.length !== 1 ? 's' : '' %>
                        </span>
                    <% } %>
                </div>
                <div class="camp-card-body">
                    <h5 class="camp-card-title"><%= campground.title %></h5>
                    <div class="camp-card-location">
                        <i class="fas fa-map-marker-alt"></i>
                        <%= campground.location || 'Location not listed' %>
                    </div>
                    <p class="camp-card-desc"><%= campground.description %></p>
                    <div class="camp-card-footer">
                        <span class="btn-view">
                            View Campground <i class="fas fa-arrow-right"></i>
                        </span>
                        <i class="fas fa-chevron-right card-arrow"></i>
                    </div>
                </div>
            </a>
        <% }) %>
    </div>

</div>

<!-- FOOTER BAR -->
<div class="page-footer-bar">
    <span class="footer-brand">Yelp<span>Camp</span></span>
    <small style="color:#333;">&copy; <%= new Date().getFullYear() %> All rights reserved</small>
</div>

<!-- MAPBOX JS -->
<script src='https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.js'></script>

<script>
    const mapToken = '<%- mapBoxToken %>';

    // Build GeoJSON — only campgrounds that have geometry
    const geojsonData = {
        type: 'FeatureCollection',
        features: <%- JSON.stringify(
            campgrounds
                .filter(c => c.geometry && c.geometry.coordinates && c.geometry.coordinates.length === 2)
                .map(c => ({
                    type: 'Feature',
                    properties: {
                        id:          c._id,
                        title:       c.title,
                        location:    c.location || '',
                        price:       c.price || 0,
                        description: (c.description || '').substring(0, 120),
                        image:       c.images && c.images.length ? c.images[0].url : ''
                    },
                    geometry: c.geometry
                }))
        ) %>
    };

    if (!mapToken) {
        document.getElementById('map').innerHTML =
            '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#555;background:#181b26;font-family:sans-serif;">Map unavailable — missing token</div>';
    } else {
        mapboxgl.accessToken = mapToken;

        const map = new mapboxgl.Map({
            container: 'map',
            style: 'mapbox://styles/mapbox/dark-v11',
            center: [-103.5917, 40.6699],
            zoom: 3
        });

        map.addControl(new mapboxgl.NavigationControl(), 'top-right');

        map.on('load', function () {

            // ── SOURCE WITH CLUSTERING ──
            map.addSource('campgrounds', {
                type: 'geojson',
                data: geojsonData,
                cluster: true,
                clusterMaxZoom: 13,
                clusterRadius: 50
            });

            // ── CLUSTER CIRCLES ──
            map.addLayer({
                id: 'clusters',
                type: 'circle',
                source: 'campgrounds',
                filter: ['has', 'point_count'],
                paint: {
                    'circle-color': [
                        'step', ['get', 'point_count'],
                        '#2d5a3d',    // 1–9
                        10, '#3a7a52', // 10–29
                        30, '#7ed99a'  // 30+
                    ],
                    'circle-radius': [
                        'step', ['get', 'point_count'],
                        18, 10, 24, 30, 30
                    ],
                    'circle-stroke-width': 2,
                    'circle-stroke-color': '#7ed99a',
                    'circle-opacity': 0.9
                }
            });

            // ── CLUSTER COUNT LABELS ──
            map.addLayer({
                id: 'cluster-count',
                type: 'symbol',
                source: 'campgrounds',
                filter: ['has', 'point_count'],
                layout: {
                    'text-field': ['get', 'point_count_abbreviated'],
                    'text-font': ['DIN Offc Pro Medium', 'Arial Unicode MS Bold'],
                    'text-size': 13
                },
                paint: { 'text-color': '#f0ede6' }
            });

            // ── INDIVIDUAL POINTS ──
            map.addLayer({
                id: 'unclustered-point',
                type: 'circle',
                source: 'campgrounds',
                filter: ['!', ['has', 'point_count']],
                paint: {
                    'circle-color': '#3a7a52',
                    'circle-radius': 8,
                    'circle-stroke-width': 2,
                    'circle-stroke-color': '#7ed99a',
                    'circle-opacity': 0.95
                }
            });

            // ── CLICK CLUSTER → ZOOM IN ──
            map.on('click', 'clusters', function (e) {
                const features = map.queryRenderedFeatures(e.point, { layers: ['clusters'] });
                const clusterId = features[0].properties.cluster_id;
                map.getSource('campgrounds').getClusterExpansionZoom(clusterId, function (err, zoom) {
                    if (err) return;
                    map.easeTo({ center: features[0].geometry.coordinates, zoom });
                });
            });

            // ── CLICK POINT → POPUP ──
            map.on('click', 'unclustered-point', function (e) {
                const coords = e.features[0].geometry.coordinates.slice();
                const { id, title, location, price, description, image } = e.features[0].properties;

                while (Math.abs(e.lngLat.lng - coords[0]) > 180) {
                    coords[0] += e.lngLat.lng > coords[0] ? 360 : -360;
                }

                const imgHtml = image
                    ? `<img class="popup-img" src="${image}" alt="${title}">`
                    : `<div class="popup-no-img"><i class="fas fa-campground"></i></div>`;

                const priceHtml = price ? `<div class="popup-price">$${price}/night</div>` : '';

                new mapboxgl.Popup({ offset: 20, maxWidth: '260px' })
                    .setLngLat(coords)
                    .setHTML(`
                        ${imgHtml}
                        <div class="popup-body">
                            <div class="popup-title">${title}</div>
                            <div class="popup-location"><i class="fas fa-map-marker-alt"></i>${location}</div>
                            ${priceHtml}
                            <a href="/campgrounds/${id}" class="popup-btn">View Campground →</a>
                        </div>
                    `)
                    .addTo(map);
            });

            // ── CURSOR POINTER ON HOVER ──
            ['clusters', 'unclustered-point'].forEach(layer => {
                map.on('mouseenter', layer, () => map.getCanvas().style.cursor = 'pointer');
                map.on('mouseleave', layer, () => map.getCanvas().style.cursor = '');
            });
        });
    }
</script>